msg.cui.cdsResult.httpServer = "更新伺服器發生通訊錯誤 (%1$s)。請稍後再試一次，如果問題仍存在，請連絡 Omnissa 支援或您的系統管理員。"
msg.cui.cdsResult.httpTimeoutError = "與更新伺服器的連線已逾時。請稍後再試一次。如果問題仍存在，請連絡 Omnissa 支援或您的系統管理員。"
msg.cui.cdsResult.httpUnauthorizedError = "更新伺服器發生授權錯誤 (HTTP 401)。請檢查您的網際網路設定或連絡您的系統管理員。"
msg.cui.cdsResult.internalClientError = "軟體更新內部用戶端錯誤 (%1$s)。請連絡 Omnissa 支援或您的系統管理員。"

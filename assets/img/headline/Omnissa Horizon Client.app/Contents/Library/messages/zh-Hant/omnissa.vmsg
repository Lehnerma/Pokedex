msg.cui.cdsResult.httpConnectError = "無法連線到更新伺服器。請檢查您的網際網路設定或連絡您的系統管理員。"
msg.cui.cdsResult.httpConnectionLostError = "與更新伺服器的連線已中斷。請稍後再試一次。如果問題仍存在，請連絡 Omnissa 支援或您的系統管理員。"
msg.cui.cdsResult.httpForbiddenError = "更新伺服器發生通訊錯誤 (HTTP 403)。請檢查您的網際網路設定或連絡您的系統管理員。"

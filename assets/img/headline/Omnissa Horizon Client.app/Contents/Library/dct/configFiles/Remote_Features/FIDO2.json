{
  "featureName": "FIDO2 Redirection",
  "logLevelSettings": {
     "files": [
       {
         "path": "~/Library/Preferences/Omnissa Horizon Client/config",
         "key": "fido2Client.Fido2Logger.logLevel",
         "logLevelMapping": {
           "INFO": "info",
           "DEBUG": "debug",
           "TRACE": "trace",
           "VERBOSE": "verbose"
         }
       },
       {
         "path": "~/Library/Preferences/Omnissa Horizon Client/config",
         "key": "fido2Client.libfido2Logging",
         "logLevelMapping": {
           "INFO": "false",
           "DEBUG": "false",
           "TRACE": "true",
           "VERBOSE": "true"
         }
       }
     ]
  },
  "logCollectionSettings": {
    "paths": [
      {
        "srcfolder": "OMNISSA_LOG_DIR",
        "rule": "horizon-fido2Client*"
      }
    ]
  }
}

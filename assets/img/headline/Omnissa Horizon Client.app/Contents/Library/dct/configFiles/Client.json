{
  "featureName": "Client",
  "logLevelSettings": {
    "userDefaults": [
      {
        "domain": "com.omnissa.horizon.client.mac",
        "key": "LogLevel",
        "logLevelMapping": {
          "INFO": "3",
          "DEBUG": "2",
          "TRACE": "1",
          "VERBOSE": "0"
        }
      }
    ]
  },
  "logCollectionSettings": {
    "paths": [
      {
        "srcfolder": "CLIENT_UI_DIR",
        "rule": "horizon-client-*.log"
      },
      {
        "srcfolder": "OMNISSA_LOG_DIR",
        "rule": "horizon-crtbora-*"
      },
      {
        "srcfolder": "OMNISSA_LOG_DIR",
        "rule": "horizon-protocol-*"
      },
      {
        "srcfolder": "/Library/Preferences",
        "tgtfolder": "Preferences/SystemPreference",
        "rule": "com.omnissa.horizon.client.mac.plist"
      },
      {
        "srcfolder": "~/Library/Preferences",
        "tgtfolder": "Preferences",
        "rule": "com.omnissa.horizon.client.mac.plist"
      }
    ]
  },
  "dumpCollectionSettings": {
    "paths": [
      {
        "srcfolder": "~/Library/Logs/DiagnosticReports",
        "tgtfolder": "Dump",
        "rule": "horizon-*"
      }
    ]
  }
}
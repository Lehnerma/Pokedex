{
  "featureName": "Real-Time Audio-Video",
  "logLevelSettings": {
    "userDefaults": [
      {
        "domain": "com.omnissa.rtav",
        "key": "LogLevel",
        "logLevelMapping": {
          "INFO": "info",
          "DEBUG": "debug",
          "TRACE": "trace",
          "VERBOSE": "trace"
        }
      },
      {
        "domain": "com.omnissa.rtav",
        "key": "DebugEnableExtraLogs",
        "logLevelMapping": {
          "INFO": "0",
          "DEBUG": "0",
          "TRACE": "8",
          "VERBOSE": "8"
        }
      }
    ]
  },
  "logCollectionSettings": {
    "paths": [
      {
        "srcfolder": "OMNISSA_LOG_DIR",
        "rule": "horizon-RTAV*"
      }
    ]
  }
}

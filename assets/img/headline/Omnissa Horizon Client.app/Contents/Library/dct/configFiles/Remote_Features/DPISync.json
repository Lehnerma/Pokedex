{
  "featureName": "DPI Synchronization",
  "logLevelSettings": {
    "tips": "Warning: This change also impacts the log levels for the client and remote features.",
    "userDefaults": [
      {
        "domain": "com.omnissa.horizon.client.mac",
        "key": "LogLevel",
        "logLevelMapping": {
          "INFO": "3",
          "DEBUG": "2",
          "TRACE": "1",
          "VERBOSE": "0"
        }
      }
    ]
  },
  "logCollectionSettings": {
    "paths": [
      {
        "srcfolder": "CLIENT_UI_DIR",
        "rule": "horizon-client-*"
      },
      {
        "srcfolder": "OMNISSA_LOG_DIR",
        "rule": "horizon-crtbora-*"
      },
      {
        "srcfolder": "OMNISSA_LOG_DIR",
        "rule": "horizon-protocol-*"
      },
      {
        "srcfolder": "OMNISSA_LOG_DIR",
        "rule": "horizon-rdeSvc-*"
      },
      {
        "srcfolder": "OMNISSA_LOG_DIR",
        "rule": "horizon-vdpService-Client*"
      }
    ]
  }
}
